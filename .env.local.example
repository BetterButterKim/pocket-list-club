# ── Supabase ───────────────────────────────────────────
# Supabase 대시보드 > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...(anon public 키)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...(service_role 키 · 절대 외부 노출 금지)

# ── Slack ──────────────────────────────────────────────
# Slack 앱 설정 > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxx
# Slack 앱 설정 > OAuth & Permissions > Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-xxxxxxxx

# ── 내부 write API 시크릿 ─────────────────────────────
# 슬랙봇(pocket-list-slackbot) Vercel에도 동일한 값을 세팅해야 슬랙 커맨드가 동작
# 값이 비어있으면 게이트가 비활성화되고 예전처럼 아무나 write 가능
PLC_INTERNAL_SECRET=change-me-to-a-long-random-string
